global_defs {
    enable_script_security
    script_user root
}

vrrp_script chk_haproxy {
    script "/etc/keepalived/check_haproxy.sh"
    interval 2
    weight -20
}

vrrp_instance VI_1 {

    state BACKUP

    interface {{ vip_interface }}

    virtual_router_id 51

    priority {{ keepalived_priority }}

    advert_int 1

    authentication {
        auth_type PASS
        auth_pass k8sha
    }

    virtual_ipaddress {
        {{ vip_address }}
    }

    track_script {
        chk_haproxy
    }
}